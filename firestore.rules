rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: lectura pública, escritura controlada
    match /users/{userId} {
      allow read: if true;

      // CUALQUIER usuario autenticado puede crear su PROPIO documento
      allow create: if request.auth != null && request.auth.uid == userId;

      // El propio usuario puede editar su perfil (excepto puntos y admin)
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'isAdmin']);

      // Admin puede editar cualquier campo de cualquier usuario
      allow update: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;

      // Solo admin puede eliminar usuarios
      allow delete: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Apuestas: lectura pública, escritura SOLO del propietario
    match /bets/{betId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Partidos: solo admin escribe
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Historial: lectura pública, creación autenticada (solo app, no editar/borrar)
    match /history/{entryId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Colecciones de cache/config: solo admin escribe
    match /worldCupCache/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
